# ===================================
# .env.example - Variables de Entorno
# ===================================
# COPIAR ESTE ARCHIVO A .env Y AJUSTAR SEGÚN SEA NECESARIO

# ===================================
# PostgreSQL
# ===================================
POSTGRES_DB=sportmap_db
POSTGRES_USER=alex
POSTGRES_PASSWORD=121416
POSTGRES_HOST=sportmap-db
POSTGRES_PORT=5432

# ===================================
# pgAdmin
# ===================================
PGADMIN_DEFAULT_EMAIL=alex@gmail.com
PGADMIN_DEFAULT_PASSWORD=121416

# ===================================
# Redis
# ===================================
REDIS_HOST=sportmap-redis
REDIS_PORT=6379

# ===================================
# App Configuration
# ===================================
APP_NAME=SportMap
APP_ENV=development
APP_DEBUG=true

# ===================================
# Database Connection String
# ===================================
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://alex:121416@sportmap-db:5432/sportmap_db
